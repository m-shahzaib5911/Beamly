# CipherBeam Configuration
PORT=3000

# MySQL Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=cipherbeam

# Link expiry in minutes
LINK_EXPIRY_MINUTES=60

# Session Secret (change in production)
SESSION_SECRET=

# Encrypted Vault Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5368709120

# SMTP Configuration (for password reset, OTP emails)
# Preferred keys:
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=
# SMTP_FROM_NAME=Beamly
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_RESOLVE_HOST=false
# SMTP_TLS_SERVERNAME=
# SMTP_VERIFY_ON_STARTUP=true
# SMTP_VERIFY_TIMEOUT_MS=15000
# SMTP_VERIFY_RETRIES=3
# SMTP_VERIFY_RETRY_DELAY_MS=3000
# SMTP_CONNECTION_TIMEOUT_MS=15000
# SMTP_GREETING_TIMEOUT_MS=15000
# SMTP_SOCKET_TIMEOUT_MS=30000
# SMTP_DNS_TIMEOUT_MS=10000
# SMTP_RETRY_WITH_RESOLVED_HOST=true
# SMTP_DNS_SERVERS=1.1.1.1,8.8.8.8
#
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Beamly
SMTP_VERIFY_TIMEOUT_MS=30000
SMTP_VERIFY_RETRIES=5
SMTP_VERIFY_RETRY_DELAY_MS=4000
SMTP_RETRY_WITH_RESOLVED_HOST=true

# Legacy keys still supported:
# GMAIL_USER=
# GMAIL_PASSWORD=

# Mailtrap Email Delivery (optional, comment out if using SMTP)
# MAILTRAP_TOKEN=8d1bfb6e2ea87e32dbe9b2ace2eecd46
# MAILTRAP_SENDER_EMAIL=hello@demomailtrap.co
# MAILTRAP_SENDER_NAME=Beamly Verification
