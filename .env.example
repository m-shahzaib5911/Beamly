# ═══════════════════════════════════════════════════════════════
# Beamly Configuration Template
# Copy this file to .env and fill in your actual values
# ═══════════════════════════════════════════════════════════════

# Server Port
PORT=3000

# ─────────────────────────────────────────────────────────────────
# MySQL Database Configuration
# ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_secure_password_here
DB_NAME=cipherbeam

# ─────────────────────────────────────────────────────────────────
# Security & Session
# ─────────────────────────────────────────────────────────────────
# Generate a random secure string for production
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your_session_secret_here

# ─────────────────────────────────────────────────────────────────
# File Management
# ─────────────────────────────────────────────────────────────────
# Directory where encrypted files are stored
UPLOAD_DIR=./uploads

# Maximum file size in bytes (default: 5GB)
MAX_FILE_SIZE=5368709120

# Link expiry time in minutes
LINK_EXPIRY_MINUTES=60

# ─────────────────────────────────────────────────────────────────
# Email Configuration (SMTP for OTP & Password Reset)
# ─────────────────────────────────────────────────────────────────
# Gmail example:
# 1. Enable 2-factor authentication on your Google account
# 2. Generate an App Password at https://myaccount.google.com/apppasswords
# 3. Use that password below

SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM_EMAIL=your_email@gmail.com
SMTP_FROM_NAME=Beamly
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# Additional SMTP options
SMTP_VERIFY_TIMEOUT_MS=30000
SMTP_VERIFY_RETRIES=5
SMTP_VERIFY_RETRY_DELAY_MS=4000
SMTP_RETRY_WITH_RESOLVED_HOST=true

# ─────────────────────────────────────────────────────────────────
# Optional: Other SMTP Providers
# ─────────────────────────────────────────────────────────────────
# Outlook:
# SMTP_HOST=smtp.outlook.com
# SMTP_PORT=587
# SMTP_SECURE=false

# SendGrid:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_USER=apikey
# SMTP_PASSWORD=your_sendgrid_api_key

# Mailtrap (Testing):
# SMTP_HOST=smtp.mailtrap.io
# SMTP_PORT=465
# SMTP_SECURE=true
